# VDX Glass Engine — Variáveis de Ambiente
# Copiar para .env e preencher os valores reais.
# NUNCA commitar o .env com valores reais.

# ── Auth ──────────────────────────────────────────────────────────────────────
# Chave mestra da API (Header X-VDX-Key ou query param key=)
VDX_API_MASTER_KEY=vdx-dev-key-local

# ── AI (Anthropic Claude) ─────────────────────────────────────────────────────
# Necessário para: chat, claude_teacher, render_validator, image_generator
# Sem esta chave o sistema opera em modo degradado (fallback legado)
ANTHROPIC_API_KEY=sk-ant-...

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
VDX_DEBUG=false

# ── Banco de dados ────────────────────────────────────────────────────────────
# Caminho absoluto ou relativo ao diretório do projeto
DB_PATH=data/constitution.db

# ── Upload / Image Generator ──────────────────────────────────────────────────
# Diretório onde imagens geradas são salvas
APP_UPLOAD_DIR=./uploads

# Caminho para o Python do venv de geração de imagens (SD 1.5)
# Só necessário se o endpoint /api/v1/tipologia/{chave}/image estiver ativo
IMAGEGEN_VENV_PATH=/home/sw3innovation/vdx-imagegen/bin/python3

# ── View Tokens (viewer 3D compartilhável) ────────────────────────────────────
# Segredo para assinar os JWTs do viewer. OBRIGATÓRIO em produção.
# Gerar: python3 -c "import secrets; print(secrets.token_hex(32))"
VDX_VIEW_TOKEN_SECRET=

# TTL padrão do view token em segundos (padrão: 3600 = 1h)
VDX_VIEW_TOKEN_TTL_SECONDS=3600

# TTL máximo que o cliente pode solicitar (padrão: 86400 = 24h)
VDX_VIEW_TOKEN_MAX_TTL_SECONDS=86400
